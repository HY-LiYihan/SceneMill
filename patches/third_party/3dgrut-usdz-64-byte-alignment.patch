+def _write_usdz_aligned(zip_file: zipfile.ZipFile, filename: str, data: Union[str, bytes]) -> None:
+    """Write an uncompressed USDZ member with 64-byte aligned file data."""
+    if isinstance(data, str):
+        data = data.encode("utf-8")
+
+    filename_bytes = filename.encode("utf-8")
+    header_offset = zip_file.fp.tell()
+    base_data_offset = header_offset + 30 + len(filename_bytes)
+    extra_len = (-base_data_offset) % 64
+    if 0 < extra_len < 4:
+        extra_len += 64
+
+    info = zipfile.ZipInfo(filename)
+    info.compress_type = zipfile.ZIP_STORED
+    info.external_attr = 0o644 << 16
+    if extra_len:
+        info.extra = (0xFFFF).to_bytes(2, "little") + (extra_len - 4).to_bytes(2, "little") + b"\0" * (extra_len - 4)
+
+    zip_file.writestr(info, data)
+
+
